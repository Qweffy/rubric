GROQ_API_KEY=
RUBRIC_JUDGE=groq
RUBRIC_JUDGE_MODEL=openai/gpt-oss-120b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Database (libSQL). Leave the Turso vars empty for local file dev — the driver
# falls back to a plain SQLite file at RUBRIC_DB. Set both for Turso/prod
# (e.g. Vercel serverless backed by hosted Turso).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
RUBRIC_DB=./rubric.db
